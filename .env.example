# ──────────────────────────────────────
# Loop 环境变量配置
# 复制本文件为 .env 并按需修改
# ──────────────────────────────────────

# 配置文件路径（默认：./config.json）
# LOOP_CONFIG=./config.json

# 日志目录（默认：./logs）
# LOOP_LOG_DIR=./logs

# 是否并发执行 Claude（默认：false，即串行）
# true  = 并发：收到多个事件时同时运行多个 Claude 实例
# false = 串行：事件排队依次执行，同一订阅同时只运行一个 Claude
# LOOP_CONCURRENT=false
